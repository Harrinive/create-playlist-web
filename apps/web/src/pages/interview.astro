---
import BaseLayout from '../layouts/BaseLayout.astro';
import StepKicker from '../components/StepKicker.astro';
import PageExitNav from '../components/PageExitNav.astro';
import { FLOW_PAGE_HEADINGS } from '../lib/flow-steps';
import { FLOW_EXIT_NAV } from '../lib/flow-nav-copy';
---

<BaseLayout title="Interview">
    <section id="interview-wizard">
        <header class="interview-page-header">
            <StepKicker step={1} />
            <h1 class="page-title">
                <span data-locale="en">{FLOW_PAGE_HEADINGS.interview.en}</span>
                <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.interview.zh}</span>
            </h1>
        </header>
        <div id="interview-stack" class="interview-stack">
            <div class="interview-loading" data-interview-boot>
                <p class="interview-loading__text">
                    <span data-locale="en">Please wait…</span>
                    <span data-locale="zh" hidden>请稍候…</span>
                </p>
                <p class="interview-loading__hint">
                    <span data-locale="en">Preparing your next question</span>
                    <span data-locale="zh" hidden>正在准备下一题</span>
                </p>
            </div>
        </div>
        <PageExitNav ariaLabelEn="Leave interview" ariaLabelZh="离开访谈">
            <a class="text-link-button" href="/">
                <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
            </a>
        </PageExitNav>
    </section>
</BaseLayout>

<script>
    import { initInterviewWizard } from '../scripts/interview-wizard.ts';

    document.addEventListener('astro:page-load', () => initInterviewWizard());
</script>
