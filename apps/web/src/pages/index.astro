---
import siteConfig from '../data/site-config';
import BaseLayout from '../layouts/BaseLayout.astro';
import { FLOW_HOW_IT_WORKS, FLOW_STEP_KICKERS } from '../lib/flow-steps';
---

<BaseLayout>
    <p class="page-kicker">
        <span data-locale="en">Mood <span class="symbol-arrow" aria-hidden="true">→</span> music</span>
        <span data-locale="zh" hidden>氛围 <span class="symbol-arrow" aria-hidden="true">→</span> 音乐</span>
    </p>
    <h1 class="page-title">
        <span data-locale="en">{siteConfig.homeHeading.en}</span>
        <span data-locale="zh" hidden>{siteConfig.homeHeading.zh}</span>
    </h1>
    <p class="intro-lead">
        <span data-locale="en">{siteConfig.description.en}</span>
        <span data-locale="zh" hidden>{siteConfig.description.zh}</span>
    </p>

    <div class="actions-row" id="home-interview-actions">
        <a class="text-link-button text-link-button--primary" href="/interview">
            <span data-locale="en">
                <span data-home-interview-label="start">Start interview</span>
                <span data-home-interview-label="continue" hidden>Continue interview</span>
            </span>
            <span data-locale="zh" hidden>
                <span data-home-interview-label="start">开始访谈</span>
                <span data-home-interview-label="continue" hidden>继续访谈</span>
            </span>
        </a>
    </div>

    <h2 class="section-title">
        <span data-locale="en">How it works</span>
        <span data-locale="zh" hidden>如何使用</span>
    </h2>
    <div class="how-steps">
        {
            FLOW_HOW_IT_WORKS.map((item) => (
                <div>
                    <p class="how-step__label">
                        <span data-locale="en">{FLOW_STEP_KICKERS[item.step].en}</span>
                        <span data-locale="zh" hidden>
                            {FLOW_STEP_KICKERS[item.step].zh}
                        </span>
                    </p>
                    <p class="how-step__text">
                        <span data-locale="en">{item.text.en}</span>
                        <span data-locale="zh" hidden>{item.text.zh}</span>
                    </p>
                </div>
            ))
        }
    </div>
</BaseLayout>

<script>
    import '../scripts/home-page.ts';
</script>
