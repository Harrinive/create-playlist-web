---
import BaseLayout from '../layouts/BaseLayout.astro';
import InterviewMissing from '../components/InterviewMissing.astro';
import PageExitNav from '../components/PageExitNav.astro';
import PageFlowActions from '../components/PageFlowActions.astro';
import StepKicker from '../components/StepKicker.astro';
import { CATALOG_CURATE_MODELS } from '../data/model-catalog';
import { DELIVERY_COPY } from '../lib/delivery-copy';
import { FLOW_PAGE_HEADINGS } from '../lib/flow-steps';
import { FLOW_EXIT_NAV } from '../lib/flow-nav-copy';
---

<BaseLayout title="Choose delivery">
    <section id="delivery-page">
        <InterviewMissing id="delivery-missing" hidden />

        <div id="delivery-content">
            <header class="delivery-page-header">
                <StepKicker step={2} />
                <h1 class="page-title">
                    <span data-locale="en">{FLOW_PAGE_HEADINGS.delivery.en}</span>
                    <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.delivery.zh}</span>
                </h1>
            </header>

            <p id="delivery-genre-note" class="delivery-genre-note" hidden></p>

            <div id="delivery-options" class="chip-grid" role="group">
                <button type="button" class="chip-option chip-option--delivery" data-delivery="prompt">
                    <span class="chip-option__label">
                        <span data-locale="en">{DELIVERY_COPY.promptLabel.en}</span>
                        <span data-locale="zh" hidden>{DELIVERY_COPY.promptLabel.zh}</span>
                    </span>
                    <span class="chip-option__sublabel">
                        <span data-locale="en">{DELIVERY_COPY.promptSublabel.en}</span>
                        <span data-locale="zh" hidden>{DELIVERY_COPY.promptSublabel.zh}</span>
                    </span>
                </button>
                {
                    CATALOG_CURATE_MODELS.length > 0 ? (
                        CATALOG_CURATE_MODELS.map((model) => (
                            <button
                                type="button"
                                class="chip-option chip-option--delivery"
                                data-delivery="build"
                                data-model={model.id}
                            >
                                <span class="chip-option__label">
                                    <span data-locale="en">{model.labelEn}</span>
                                    <span data-locale="zh" hidden>{model.labelZh}</span>
                                </span>
                                <span class="chip-option__sublabel">
                                    <span data-locale="en">{DELIVERY_COPY.buildSublabelSpotify.en}</span>
                                    <span data-locale="zh" hidden>{DELIVERY_COPY.buildSublabelSpotify.zh}</span>
                                </span>
                            </button>
                        ))
                    ) : (
                        <button type="button" class="chip-option chip-option--delivery" data-delivery="build">
                            <span class="chip-option__label">
                                <span data-locale="en">{DELIVERY_COPY.buildFallbackLabel.en}</span>
                                <span data-locale="zh" hidden>{DELIVERY_COPY.buildFallbackLabel.zh}</span>
                            </span>
                            <span class="chip-option__sublabel">
                                <span data-locale="en">{DELIVERY_COPY.buildSublabelAccount.en}</span>
                                <span data-locale="zh" hidden>{DELIVERY_COPY.buildSublabelAccount.zh}</span>
                            </span>
                        </button>
                    )
                }
            </div>

            <PageExitNav ariaLabelEn="Leave delivery page" ariaLabelZh="离开交付页">
                <a class="text-link-button" href="/interview">
                    <span data-locale="en">{FLOW_EXIT_NAV.backToInterview.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.backToInterview.zh}</span>
                </a>
                <a class="text-link-button" href="/">
                    <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
                </a>
            </PageExitNav>
        </div>
    </section>
</BaseLayout>

<script>
    import { initDeliveryPage } from '../scripts/delivery-page.ts';

    document.addEventListener('astro:page-load', () => initDeliveryPage());
</script>
