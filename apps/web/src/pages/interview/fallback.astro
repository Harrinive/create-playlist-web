---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageExitNav from '../../components/PageExitNav.astro';
import PageFlowActions from '../../components/PageFlowActions.astro';
import StepKicker from '../../components/StepKicker.astro';
import { INTERVIEW_FALLBACK_COPY } from '../../lib/interview-fallback-copy';
import { FLOW_EXIT_NAV } from '../../lib/flow-nav-copy';
---

<BaseLayout title="Interview pause">
    <section id="interview-fallback-page" class="interview-fallback">
        <StepKicker step={1} />
        <h1 class="page-title">
            <span data-locale="en">{INTERVIEW_FALLBACK_COPY.title.en}</span>
            <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.title.zh}</span>
        </h1>
        <p class="intro-lead">
            <span data-locale="en">{INTERVIEW_FALLBACK_COPY.body.en}</span>
            <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.body.zh}</span>
        </p>

        <p id="interview-fallback-resume-hint" class="help-line" hidden>
            <span data-locale="en">{INTERVIEW_FALLBACK_COPY.resumeHint.en}</span>
            <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.resumeHint.zh}</span>
        </p>
        <p id="interview-fallback-no-checkpoint" class="help-line" hidden>
            <span data-locale="en">{INTERVIEW_FALLBACK_COPY.noCheckpoint.en}</span>
            <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.noCheckpoint.zh}</span>
        </p>

        <PageFlowActions>
            <a
                id="interview-fallback-resume"
                class="text-link-button text-link-button--primary"
                href="/interview"
                hidden
            >
                <span data-locale="en">{INTERVIEW_FALLBACK_COPY.resumeButton.en}</span>
                <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.resumeButton.zh}</span>
            </a>
            <button type="button" id="interview-fallback-start-over" class="text-link-button">
                <span data-locale="en">{INTERVIEW_FALLBACK_COPY.startOverButton.en}</span>
                <span data-locale="zh" hidden>{INTERVIEW_FALLBACK_COPY.startOverButton.zh}</span>
            </button>
        </PageFlowActions>

        <PageExitNav ariaLabelEn="Leave interview" ariaLabelZh="离开访谈">
            <a class="text-link-button" href="/">
                <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
            </a>
        </PageExitNav>
    </section>
</BaseLayout>

<script>
    import { initInterviewFallbackPage } from '../../scripts/interview-fallback-page.ts';

    document.addEventListener('astro:page-load', () => initInterviewFallbackPage());
</script>
