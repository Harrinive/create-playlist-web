---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Build on Spotify">
    <section id="build-page">
        <div id="build-missing" hidden>
            <h1 class="page-title">
                <span data-locale="en">No interview yet</span>
                <span data-locale="zh" hidden>还没有访谈</span>
            </h1>
            <p class="intro-lead">
                <span data-locale="en">Complete the interview first — we'll remember your answers for this browser session.</span>
                <span data-locale="zh" hidden>请先完成访谈 — 答案会保存在当前浏览器会话中。</span>
            </p>
            <div class="actions-row">
                <a class="text-link-button text-link-button--primary" href="/interview">
                    <span data-locale="en">Start interview</span>
                    <span data-locale="zh" hidden>开始访谈</span>
                </a>
            </div>
        </div>

        <div id="build-content" hidden>
            <p class="page-kicker">
                <span data-locale="en">Build on Spotify</span>
                <span data-locale="zh" hidden>在 Spotify 上创建</span>
            </p>
            <h1 class="page-title">
                <span data-locale="en">Create your playlist</span>
                <span data-locale="zh" hidden>创建你的歌单</span>
            </h1>
            <p id="build-status" class="help-line" hidden role="status"></p>

            <div id="build-unconfigured" hidden>
                <p class="intro-lead">
                    <span data-locale="en">
                        The build API is not configured yet. Set <code>PUBLIC_API_URL</code> when the Fly API is
                        deployed, or use the prompt path for now.
                    </span>
                    <span data-locale="zh" hidden>
                        构建 API 尚未配置。部署 Fly API 后设置 <code>PUBLIC_API_URL</code>，或暂时使用提示词路径。
                    </span>
                </p>
                <div class="actions-row">
                    <a class="text-link-button text-link-button--primary" href="/prompt">
                        <span data-locale="en">Get a prompt instead</span>
                        <span data-locale="zh" hidden>改为获取提示词</span>
                    </a>
                </div>
            </div>

            <div id="build-connect" hidden>
                <p class="intro-lead">
                    <span data-locale="en">
                        Connect Spotify to curate ~20 tracks from your interview, verify each line on Spotify, and
                        publish a private playlist to your account.
                    </span>
                    <span data-locale="zh" hidden>
                        连接 Spotify，根据访谈策展约 20 首曲目，在 Spotify 上验证并发布私密歌单到你的账号。
                    </span>
                </p>
                <div class="actions-row">
                    <a id="build-connect-btn" class="text-link-button text-link-button--primary" href="#">
                        <span data-locale="en">Connect Spotify</span>
                        <span data-locale="zh" hidden>连接 Spotify</span>
                    </a>
                    <a class="text-link-button" href="/prompt">
                        <span data-locale="en">Get a prompt instead</span>
                        <span data-locale="zh" hidden>改为获取提示词</span>
                    </a>
                </div>
            </div>

            <div id="build-connected" hidden>
                <p class="intro-lead">
                    <span data-locale="en">Connected as </span>
                    <span data-locale="zh" hidden>已连接 </span>
                    <strong id="build-user-label"></strong>
                </p>

                <div id="build-flow" class="build-flow">
                    <p id="build-model-label" class="help-line" hidden></p>
                    <p class="intro-lead">
                        <span data-locale="en">
                            We'll curate a ~26-line tracklist from your interview, verify each song on Spotify, trim to
                            ~20 tracks in listen order, then publish a private playlist.
                        </span>
                        <span data-locale="zh" hidden>
                            我们会根据访谈生成约 26 首候选曲目，在 Spotify 上验证，按聆听顺序裁剪到约 20 首，然后发布私密歌单。
                        </span>
                    </p>
                    <div class="actions-row">
                        <button id="build-start-btn" type="button" class="text-link-button text-link-button--primary">
                            <span data-locale="en">Build playlist</span>
                            <span data-locale="zh" hidden>创建歌单</span>
                        </button>
                    </div>
                    <p id="build-progress" class="help-line" hidden role="status"></p>
                </div>

                <div id="build-results" class="build-results" hidden>
                    <h2 class="build-results__title">
                        <span data-locale="en">Playlist created</span>
                        <span data-locale="zh" hidden>歌单已创建</span>
                    </h2>
                    <div id="build-results-summary" class="build-results__summary"></div>
                    <div id="build-results-order" class="build-results__section"></div>
                    <div id="build-results-skipped" class="build-results__section"></div>
                </div>

                <div id="build-fallback" class="build-fallback" hidden>
                    <p class="intro-lead">
                        <span data-locale="en">
                            Too few tracks verified on Spotify. Try the Prompted Playlist path instead — paste the
                            paragraph into Spotify's AI playlist feature.
                        </span>
                        <span data-locale="zh" hidden>
                            Spotify 上验证通过的曲目太少。请改用提示词路径 — 将段落粘贴到 Spotify 的 AI 歌单功能中。
                        </span>
                    </p>
                    <div class="actions-row">
                        <a class="text-link-button text-link-button--primary" href="/prompt">
                            <span data-locale="en">Get a prompt instead</span>
                            <span data-locale="zh" hidden>改为获取提示词</span>
                        </a>
                    </div>
                </div>

                <details class="build-advanced">
                    <summary>
                        <span data-locale="en">Test track search</span>
                        <span data-locale="zh" hidden>测试曲目搜索</span>
                    </summary>
                    <form id="build-search-form" class="build-search">
                        <label class="build-search__label" for="build-search-input">
                            <span data-locale="en">Search query</span>
                            <span data-locale="zh" hidden>搜索关键词</span>
                        </label>
                        <div class="build-search__row">
                            <input
                                id="build-search-input"
                                class="build-search__input"
                                type="search"
                                name="q"
                                placeholder="artist and track"
                                autocomplete="off"
                            />
                            <button type="submit" class="text-link-button text-link-button--primary">
                                <span data-locale="en">Search</span>
                                <span data-locale="zh" hidden>搜索</span>
                            </button>
                        </div>
                    </form>
                    <div id="build-search-results" class="build-search-results" aria-live="polite"></div>
                </details>

                <div class="actions-row">
                    <button id="build-logout-btn" type="button" class="text-link-button">
                        <span data-locale="en">Disconnect</span>
                        <span data-locale="zh" hidden>断开连接</span>
                    </button>
                    <a class="text-link-button" href="/delivery">
                        <span data-locale="en">Back to delivery</span>
                        <span data-locale="zh" hidden>返回交付选择</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    import { initBuildPage } from '../scripts/build-page.ts';

    function bootBuild() {
        initBuildPage();
    }

    bootBuild();
    document.addEventListener('astro:page-load', bootBuild);
</script>
