---
import BaseLayout from '../layouts/BaseLayout.astro';
import InterviewMissing from '../components/InterviewMissing.astro';
import PageExitNav from '../components/PageExitNav.astro';
import PageFlowActions from '../components/PageFlowActions.astro';
import StepKicker from '../components/StepKicker.astro';
import { FLOW_PAGE_HEADINGS } from '../lib/flow-steps';
import { FLOW_EXIT_NAV } from '../lib/flow-nav-copy';
import { SERVICE_UNAVAILABLE_COPY } from '../lib/service-copy';
---

<BaseLayout title="Generate tracklist">
    <section id="build-page">
        <InterviewMissing id="build-missing" />

        <div id="build-content" hidden>
            <header class="build-page-header">
                <StepKicker step={3} />
                <h1 id="build-page-title" class="page-title">
                    <span data-title-mode="flow">
                        <span data-locale="en">{FLOW_PAGE_HEADINGS.buildFlow.en}</span>
                        <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.buildFlow.zh}</span>
                    </span>
                    <span data-title-mode="preview" hidden>
                        <span data-locale="en">{FLOW_PAGE_HEADINGS.buildPreview.en}</span>
                        <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.buildPreview.zh}</span>
                    </span>
                    <span data-title-mode="results" hidden>
                        <span data-locale="en">{FLOW_PAGE_HEADINGS.buildResults.en}</span>
                        <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.buildResults.zh}</span>
                    </span>
                    <span data-title-mode="fallback" hidden>
                        <span data-locale="en">{FLOW_PAGE_HEADINGS.buildFallback.en}</span>
                        <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.buildFallback.zh}</span>
                    </span>
                </h1>
                <p id="build-page-meta" class="page-subtitle build-page-meta" hidden></p>
                <p id="build-user-subtitle" class="page-subtitle" hidden>
                    <span data-locale="en">Connected as </span>
                    <span data-locale="zh" hidden>已连接 </span>
                    <strong id="build-user-label"></strong>
                </p>
            </header>

            <p id="build-status" class="help-line" hidden role="status"></p>

            <div id="build-unconfigured" hidden>
                <p class="intro-lead">
                    <span data-locale="en">{SERVICE_UNAVAILABLE_COPY.build.en}</span>
                    <span data-locale="zh" hidden>{SERVICE_UNAVAILABLE_COPY.build.zh}</span>
                </p>
                <PageFlowActions>
                    <a class="text-link-button text-link-button--primary" href="/prompt">
                        <span data-locale="en">Get a prompt instead</span>
                        <span data-locale="zh" hidden>改为获取提示词</span>
                    </a>
                </PageFlowActions>
                <PageExitNav ariaLabelEn="Leave build page" ariaLabelZh="离开构建页">
                    <a class="text-link-button" href="/delivery">
                        <span data-locale="en">{FLOW_EXIT_NAV.backToDelivery.en}</span>
                        <span data-locale="zh" hidden>{FLOW_EXIT_NAV.backToDelivery.zh}</span>
                    </a>
                    <a class="text-link-button" href="/">
                        <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                        <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
                    </a>
                </PageExitNav>
            </div>

            <div id="build-main">
                <div id="build-flow" class="build-flow">
                    <p id="build-model-label" class="build-flow__model" hidden></p>
                    <p class="build-flow__lead">
                        <span data-locale="en">
                            We'll draft about 20 songs from your interview and check each one on Spotify. Connect
                            your account only when you're ready to import.
                        </span>
                        <span data-locale="zh" hidden>
                            我们会根据访谈选出约 20 首歌，并在 Spotify 上逐首核对。只有准备导入时，才需要连接你的账号。
                        </span>
                    </p>
                    <PageFlowActions>
                        <button id="build-start-btn" type="button" class="text-link-button text-link-button--primary">
                            <span data-locale="en">Generate tracklist</span>
                            <span data-locale="zh" hidden>生成曲目</span>
                        </button>
                    </PageFlowActions>
                    <p id="build-progress" class="build-flow__progress" hidden role="status"></p>
                </div>

                <div id="build-preview" class="build-preview" hidden>
                    <div id="build-preview-sequence" class="build-preview__sequence" hidden></div>
                    <div id="build-preview-order" class="build-preview__tracks build-tracklist"></div>

                    <footer class="build-preview__footer">
                        <p id="build-import-note" class="build-preview__import-note">
                            <span data-locale="en">
                                Import needs Spotify access. If connect fails, the app may be in Development mode — ask
                                the site owner to add your Spotify account to the allowlist.
                            </span>
                            <span data-locale="zh" hidden>
                                导入需要 Spotify 授权。若连接失败，应用可能处于开发模式 — 请联系站点管理员将你的
                                Spotify 账号加入允许列表。
                            </span>
                        </p>
                        <div class="build-preview__primary">
                            <button
                                id="build-import-btn"
                                type="button"
                                class="text-link-button text-link-button--primary"
                            >
                                <span data-locale="en" data-import-label="connect">Connect Spotify to import</span>
                                <span data-locale="en" data-import-label="import" hidden>Import to Spotify</span>
                                <span data-locale="zh" hidden data-import-label="connect">连接 Spotify 以导入</span>
                                <span data-locale="zh" hidden data-import-label="import">导入到 Spotify</span>
                            </button>
                        </div>
                        <PageFlowActions variant="secondary">
                            <button id="build-regenerate-btn" type="button" class="text-link-button">
                                <span data-locale="en">Regenerate</span>
                                <span data-locale="zh" hidden>重新生成</span>
                            </button>
                            <a class="text-link-button" href="/prompt">
                                <span data-locale="en">Use prompt instead</span>
                                <span data-locale="zh" hidden>改用提示词</span>
                            </a>
                        </PageFlowActions>
                        <p id="build-import-progress" class="build-flow__progress" hidden role="status"></p>
                    </footer>
                </div>

                <div id="build-results" class="build-results" hidden>
                    <div id="build-results-summary" class="build-results__summary"></div>
                    <div id="build-results-order" class="build-results__section"></div>
                </div>

                <div id="build-fallback" class="build-fallback" hidden>
                    <p id="build-fallback-body" class="intro-lead"></p>
                    <PageFlowActions>
                        <a class="text-link-button text-link-button--primary" href="/prompt">
                            <span data-locale="en">Get a prompt instead</span>
                            <span data-locale="zh" hidden>改为获取提示词</span>
                        </a>
                        <button id="build-fallback-regenerate" type="button" class="text-link-button">
                            <span data-locale="en">Regenerate</span>
                            <span data-locale="zh" hidden>重新生成</span>
                        </button>
                    </PageFlowActions>
                </div>

                <PageExitNav ariaLabelEn="Leave build page" ariaLabelZh="离开构建页">
                    <button id="build-logout-btn" type="button" class="text-link-button" hidden>
                        <span data-locale="en">Disconnect</span>
                        <span data-locale="zh" hidden>断开连接</span>
                    </button>
                    <a class="text-link-button" href="/delivery">
                        <span data-locale="en">{FLOW_EXIT_NAV.backToDelivery.en}</span>
                        <span data-locale="zh" hidden>{FLOW_EXIT_NAV.backToDelivery.zh}</span>
                    </a>
                    <a class="text-link-button" href="/">
                        <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                        <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
                    </a>
                </PageExitNav>
            </div>
        </div>
    </section>
</BaseLayout>

<script>
    import { initBuildPage } from '../scripts/build-page.ts';

    document.addEventListener('astro:page-load', () => initBuildPage());
</script>
