---
import BaseLayout from '../layouts/BaseLayout.astro';
import InterviewMissing from '../components/InterviewMissing.astro';
import PageExitNav from '../components/PageExitNav.astro';
import PageFlowActions from '../components/PageFlowActions.astro';
import StepKicker from '../components/StepKicker.astro';
import { FLOW_PAGE_HEADINGS, FLOW_STEP3_PROMPT_SUBTITLE } from '../lib/flow-steps';
import { FLOW_EXIT_NAV, FLOW_SESSION_ACTIONS } from '../lib/flow-nav-copy';
import { SERVICE_UNAVAILABLE_COPY } from '../lib/service-copy';
---

<BaseLayout title="Your prompt">
    <section id="prompt-page">
        <InterviewMissing id="prompt-missing" />

        <div id="prompt-unconfigured" hidden>
            <header class="prompt-page-header">
                <StepKicker step={3} />
                <h1 class="page-title">
                    <span data-locale="en">{FLOW_PAGE_HEADINGS.prompt.en}</span>
                    <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.prompt.zh}</span>
                </h1>
            </header>
            <p class="intro-lead">
                <span data-locale="en">{SERVICE_UNAVAILABLE_COPY.prompt.en}</span>
                <span data-locale="zh" hidden>{SERVICE_UNAVAILABLE_COPY.prompt.zh}</span>
            </p>
            <PageExitNav ariaLabelEn="Leave prompt page" ariaLabelZh="离开提示词页">
                <a class="text-link-button" href="/delivery">
                    <span data-locale="en">{FLOW_EXIT_NAV.otherDelivery.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.otherDelivery.zh}</span>
                </a>
                <a class="text-link-button" href="/">
                    <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
                </a>
            </PageExitNav>
        </div>

        <div id="prompt-body" hidden>
            <header class="prompt-page-header">
                <StepKicker step={3} />
                <h1 class="page-title">
                    <span data-locale="en">{FLOW_PAGE_HEADINGS.prompt.en}</span>
                    <span data-locale="zh" hidden>{FLOW_PAGE_HEADINGS.prompt.zh}</span>
                </h1>
                <p class="page-subtitle">
                    <span data-locale="en">{FLOW_STEP3_PROMPT_SUBTITLE.en}</span>
                    <span data-locale="zh" hidden>{FLOW_STEP3_PROMPT_SUBTITLE.zh}</span>
                </p>
            </header>

            <div id="prompt-loading">
                <p class="intro-lead" role="status">
                    <span data-locale="en">Drafting your Spotify prompt…</span>
                    <span data-locale="zh" hidden>正在撰写 Spotify 提示词…</span>
                </p>
            </div>

            <div id="prompt-error" hidden>
                <p id="prompt-error-text" class="intro-lead" role="alert"></p>
                <PageFlowActions>
                    <button id="prompt-retry" type="button" class="text-link-button text-link-button--primary">
                        <span data-locale="en">Try again</span>
                        <span data-locale="zh" hidden>重试</span>
                    </button>
                    <button type="button" class="text-link-button" data-action="start-over">
                        <span data-locale="en">{FLOW_SESSION_ACTIONS.startOver.en}</span>
                        <span data-locale="zh" hidden>{FLOW_SESSION_ACTIONS.startOver.zh}</span>
                    </button>
                </PageFlowActions>
            </div>

            <div id="prompt-content" hidden>
                <div id="prompt-text" class="prompt-block"></div>

                <div class="prompt-footer">
                    <PageFlowActions>
                        <button id="copy-prompt" type="button" class="text-link-button text-link-button--primary">
                            <span data-locale="en">Copy prompt</span>
                            <span data-locale="zh" hidden>复制提示词</span>
                        </button>
                        <span id="copy-status" class="copy-status" role="status" aria-live="polite"></span>
                    </PageFlowActions>

                    <p class="prompt-footer__help">
                        <span data-locale="en">
                            Paste into Spotify → Library → Create → <strong>Prompted Playlist</strong>.
                        </span>
                        <span data-locale="zh" hidden>
                            粘贴到 Spotify → 资料库 → 创建 → <strong>Prompted Playlist</strong>。
                        </span>
                    </p>

                    <PageFlowActions variant="secondary">
                        <button type="button" class="text-link-button" data-action="start-over">
                            <span data-locale="en">{FLOW_SESSION_ACTIONS.startOver.en}</span>
                            <span data-locale="zh" hidden>{FLOW_SESSION_ACTIONS.startOver.zh}</span>
                        </button>
                    </PageFlowActions>
                </div>
            </div>

            <PageExitNav ariaLabelEn="Leave prompt page" ariaLabelZh="离开提示词页">
                <a class="text-link-button" href="/delivery">
                    <span data-locale="en">{FLOW_EXIT_NAV.otherDelivery.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.otherDelivery.zh}</span>
                </a>
                <a class="text-link-button" href="/">
                    <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
                    <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
                </a>
            </PageExitNav>
        </div>
    </section>
</BaseLayout>

<script>
    import { initPromptPage } from '../scripts/prompt-page.ts';

    document.addEventListener('astro:page-load', () => initPromptPage());
</script>
