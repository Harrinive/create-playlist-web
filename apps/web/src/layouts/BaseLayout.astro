---
import { ClientRouter, fade } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Sidebar from '../components/Sidebar.astro';

export type Props = HeadProps;
const head = Astro.props;
const pageFade = fade({ duration: '320ms' });
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead {...head} />
        <script is:inline>
            (() => {
                const themeKey = 'theme';
                const modeKey = 'theme-mode';
                const localeKey = 'create-playlist-locale';
                let storedMode = null;
                let legacyTheme = null;
                let storedLocale = null;
                try {
                    storedMode = localStorage.getItem(modeKey);
                    legacyTheme = localStorage.getItem(themeKey);
                    storedLocale = localStorage.getItem(localeKey);
                } catch (_) {}
                const prefersDark =
                    window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                const mode =
                    storedMode === 'system' || storedMode === 'dark' || storedMode === 'light'
                        ? storedMode
                        : legacyTheme === 'dark' || legacyTheme === 'light'
                          ? legacyTheme
                          : 'system';
                const theme = mode === 'system' ? (prefersDark ? 'dark' : 'light') : mode;
                document.documentElement.dataset.theme = theme;
                document.documentElement.dataset.themeMode = mode;
                const locale = storedLocale === 'zh' ? 'zh' : 'en';
                document.documentElement.lang = locale === 'zh' ? 'zh-CN' : 'en';
            })();
        </script>
        <ClientRouter />
    </head>
    <body>
        <a class="skip-link" href="#content">
            <span data-locale="en">Skip to content</span>
            <span data-locale="zh" hidden>跳到内容</span>
        </a>
        <div class="shell">
            <Sidebar />
            <div class="divider" aria-hidden="true"></div>
            <main id="content" class="content" tabindex="-1">
                <div class="content__inner">
                    <div class="content__main" transition:name="main" transition:animate={pageFade}>
                        <slot />
                    </div>
                    <footer class="site-footer">
                        <span data-locale="en">Vibe List → Spotify</span>
                        <span data-locale="zh" hidden>氛围歌单 → Spotify</span>
                    </footer>
                </div>
            </main>
        </div>
        <script>
            import '../scripts/sidebar-theme.ts';
            import '../scripts/app-toolbar.ts';
            import '../scripts/page-metadata.ts';
        </script>
    </body>
</html>
