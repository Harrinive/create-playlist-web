---
import siteConfig from '../data/site-config';
import UiIcon from './UiIcon.astro';

const pathname = Astro.url.pathname;
const showStartOver = pathname.startsWith('/interview');
---

<aside id="site-sidebar" class="sidebar" transition:persist="sidebar">
    <div class="sidebar__top">
        <a class="sidebar__title" href="/" aria-label={siteConfig.title.en}>
            <span class="sidebar__title-text">
                <span data-locale="en">{siteConfig.title.en}</span>
                <span data-locale="zh" hidden>{siteConfig.title.zh}</span>
            </span>
        </a>

        <div class="sidebar__header-actions">
            <div class="sidebar-actions">
                <button
                    id="theme-toggle"
                    class="icon-button theme-toggle"
                    type="button"
                    aria-label="Theme"
                    data-tooltip-en="Theme"
                    data-tooltip-zh="主题"
                >
                    <UiIcon name="sun-moon" class="icon-system" />
                    <UiIcon name="moon" class="icon-moon" />
                    <UiIcon name="sun" class="icon-sun" />
                </button>
            </div>

            <button
                type="button"
                id="toolbar-menu-toggle"
                class="toolbar-menu-toggle app-toolbar__btn"
                aria-expanded="false"
                aria-controls="app-toolbar-panel"
            >
                <span data-locale="en">Menu</span>
                <span data-locale="zh" hidden>菜单</span>
                <span class="toolbar-dropdown__caret" aria-hidden="true">▾</span>
            </button>
        </div>
    </div>

    <div class="sidebar__quote">
        <span data-locale="en">
            Five questions.<br />One mood brief.<br />Spotify-ready.
        </span>
        <span data-locale="zh" hidden>
            五个选择。<br />一种氛围。<br />直达 Spotify。
        </span>
    </div>

    <div id="app-toolbar-panel" class="sidebar__toolbar-panel" hidden>
        <ul id="app-toolbar" class="app-toolbar" aria-label="App actions">
            <li class="app-toolbar__item app-toolbar__item--dropdown">
                <div class="toolbar-dropdown" id="locale-dropdown">
                    <button
                        type="button"
                        class="app-toolbar__btn toolbar-dropdown__trigger"
                        id="locale-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                        aria-controls="locale-menu"
                    >
                        <span class="toolbar-dropdown__prefix" data-locale="en">Language</span>
                        <span class="toolbar-dropdown__prefix" data-locale="zh" hidden>语言</span>
                        <span class="toolbar-dropdown__value" id="locale-label"></span>
                        <span class="toolbar-dropdown__caret" aria-hidden="true">▾</span>
                    </button>
                    <ul class="toolbar-dropdown__menu" id="locale-menu" role="listbox" hidden></ul>
                </div>
            </li>

            <li class="app-toolbar__item app-toolbar__item--dropdown">
                <div class="toolbar-dropdown" id="interview-model-dropdown">
                    <button
                        type="button"
                        class="app-toolbar__btn toolbar-dropdown__trigger"
                        id="interview-model-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                        aria-controls="interview-model-menu"
                    >
                        <span class="toolbar-dropdown__prefix" data-locale="en">Interview</span>
                        <span class="toolbar-dropdown__prefix" data-locale="zh" hidden>访谈</span>
                        <span class="toolbar-dropdown__value" id="interview-model-label"></span>
                        <span class="toolbar-dropdown__caret" aria-hidden="true">▾</span>
                    </button>
                    <ul
                        class="toolbar-dropdown__menu"
                        id="interview-model-menu"
                        role="listbox"
                        hidden
                    />
                </div>
            </li>
            <li class="app-toolbar__item app-toolbar__item--dropdown">
                <div class="toolbar-dropdown" id="interview-algorithm-dropdown">
                    <button
                        type="button"
                        class="app-toolbar__btn toolbar-dropdown__trigger"
                        id="interview-algorithm-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                        aria-controls="interview-algorithm-menu"
                    >
                        <span class="toolbar-dropdown__prefix" data-locale="en">Algorithm</span>
                        <span class="toolbar-dropdown__prefix" data-locale="zh" hidden>算法</span>
                        <span class="toolbar-dropdown__value" id="interview-algorithm-label"></span>
                        <span class="toolbar-dropdown__caret" aria-hidden="true">▾</span>
                    </button>
                    <ul
                        class="toolbar-dropdown__menu"
                        id="interview-algorithm-menu"
                        role="listbox"
                        hidden
                    />
                </div>
            </li>

            {
                showStartOver && (
                    <li class="app-toolbar__item">
                        <button type="button" class="app-toolbar__btn" id="start-over-btn" data-start-over>
                            <UiIcon name="rotate-ccw" />
                            <span data-locale="en">Start over</span>
                            <span data-locale="zh" hidden>重新开始</span>
                        </button>
                    </li>
                )
            }

            <li class="app-toolbar__item">
                <a class="app-toolbar__btn" id="last-result-link" href="/prompt">
                    <span data-locale="en" data-last-label="prompt">Last prompt</span>
                    <span data-locale="en" data-last-label="build" hidden>Last result</span>
                    <span data-locale="zh" data-last-label="prompt" hidden>上次提示</span>
                    <span data-locale="zh" data-last-label="build" hidden>上次结果</span>
                </a>
            </li>
        </ul>
    </div>
</aside>
