---
import PageExitNav from './PageExitNav.astro';
import PageFlowActions from './PageFlowActions.astro';
import { FLOW_EXIT_NAV } from '../lib/flow-nav-copy';

export type Props = {
    id: string;
};

const { id } = Astro.props;
---

<div id={id} hidden>
    <h1 class="page-title">
        <span data-locale="en">No interview yet</span>
        <span data-locale="zh" hidden>还没有访谈</span>
    </h1>
    <p class="intro-lead">
        <span data-locale="en">Complete the interview first — we'll keep your picks while you're here.</span>
        <span data-locale="zh" hidden>请先完成访谈 — 我们会暂存你的选择。</span>
    </p>
    <PageFlowActions>
        <a class="text-link-button text-link-button--primary" href="/interview">
            <span data-locale="en">Start interview</span>
            <span data-locale="zh" hidden>开始访谈</span>
        </a>
    </PageFlowActions>
    <PageExitNav ariaLabelEn="Leave page" ariaLabelZh="离开页面">
        <a class="text-link-button" href="/">
            <span data-locale="en">{FLOW_EXIT_NAV.home.en}</span>
            <span data-locale="zh" hidden>{FLOW_EXIT_NAV.home.zh}</span>
        </a>
    </PageExitNav>
</div>
