# Spotify Developer app — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/auth/spotify/callback

# Random 32+ char secret for signing OAuth state cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Web app origin — use 127.0.0.1 (not localhost) so API session cookies work in dev
WEB_ORIGIN=http://127.0.0.1:4321

# Optional — Neon Postgres. Omit for in-memory dev store (not for production).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# LLM for Step 2.2.3 curation — at least one key required for /api/curate
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CURATE_LLM_MODEL=openai:gpt-4o-mini
# LLM_MODEL=openai:gpt-4o-mini

PORT=3001
