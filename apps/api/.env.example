# Spotify Developer app — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/auth/spotify/callback

# Random 32+ char secret for signing OAuth state cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Web app origin — use 127.0.0.1 (not localhost) so API session cookies work in dev
WEB_ORIGIN=http://127.0.0.1:4321

# Optional — Neon Postgres. Omit for in-memory dev store (not for production).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# LLM for Step 2.2.3 curation — at least one key required for /api/curate
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=                    # https://cursor.com/dashboard → API Keys
# CURSOR_LLM_RUNTIME=local           # local dev; use cloud on Fly
# CURSOR_CLOUD_REPO=                 # required when runtime=cloud (e.g. https://github.com/Harrinive/create-playlist-web)
# CURSOR_CLOUD_REF=main
# CURSOR_LOCAL_CWD=                  # optional; defaults to API process cwd
# CURATE_LLM_MODEL=cursor:composer-2.5
# INTERVIEW_LLM_MODEL=openai:gpt-5.4-mini
# INTERVIEW_ALGORITHM_MODE=full   # full = plan→draft→verify; fast = single-call (legacy)

PORT=3001
