{
  "name": "create-playlist-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:verify": "node --import tsx --test src/llm/interview/__tests__/verify-deterministic.test.ts src/llm/interview/__tests__/verify-severity.test.ts src/llm/interview/__tests__/plan-m1-kinetic.test.ts src/llm/interview/__tests__/turn-plan-normalize.test.ts src/llm/interview/__tests__/verify-m1-frame.test.ts src/llm/interview/__tests__/normalize-m4-repair.test.ts",
    "test:build": "node --import tsx --test src/spotify/__tests__/client.test.ts src/routes/__tests__/build-auth.test.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.21",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.3.3",
    "pg": "^8.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
